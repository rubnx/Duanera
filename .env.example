# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Database: Neon-hosted PostgreSQL.
# Required by the app database helper and Drizzle tooling.
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/duanera?sslmode=require
# Optional direct connection URL for migration tooling; may match DATABASE_URL until pooling is configured.
DIRECT_DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/duanera?sslmode=require
# Required for local data-mutating seed/sample scripts.
# Keep production shells unset or set to a non-dev value.
DUANERA_DB_TARGET=dev
# Optional raw row payload retention mode for dev ingestion.
# Supported: full_postgres, errors_and_warnings
# Default: full_postgres
RAW_ROW_PAYLOAD_RETENTION=full_postgres
# Optional dev-only raw payload pruning controls. Dry-run unless confirm is set.
RAW_ROW_PRUNE_LIMIT=100
RAW_ROW_PRUNE_BATCH_SIZE=100
# RAW_ROW_PRUNE_FLOW=import
# RAW_ROW_PRUNE_CONFIRM=prune

# Auth
AUTH_SECRET=replace_with_long_random_secret
# Optional if using Auth.js with providers later
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Object storage: Cloudflare R2 or S3-compatible storage for raw source files
S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=duanera-raw-sources
S3_PUBLIC_BASE_URL=

# Stripe, later
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ClickHouse, later only if enabled by decision
CLICKHOUSE_URL=
CLICKHOUSE_USERNAME=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=duanera
